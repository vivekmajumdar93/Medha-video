# MEDHĀ Environment Variables
# Copy to .env.local and fill in at least one faculty key

# Prājña — OpenAI (gpt-4o)
OPENAI_API_KEY=sk-...

# Dhyāna — Anthropic (claude-sonnet)
ANTHROPIC_API_KEY=sk-ant-...

# Akṣaya — via OpenRouter (gemini)
# Sañcāra — OpenRouter (fallback routing)
OPENROUTER_API_KEY=sk-or-...

# Javā — Groq (llama-3.3-70b, free tier available)
GROQ_API_KEY=gsk_...

# App URL (for OpenRouter referer header)
NEXT_PUBLIC_APP_URL=https://medha.ai
