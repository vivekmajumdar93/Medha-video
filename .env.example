# MEDHĀ Environment Variables
# Copy to .env.local and fill in at least one faculty key

# ─── Faculty API Keys ─────────────────────────────────────────────────────────

# Prājña — OpenAI (gpt-4o)
OPENAI_API_KEY=sk-...

# Dhyāna — Anthropic (claude-sonnet). Falls back to OpenAI if absent.
ANTHROPIC_API_KEY=sk-ant-...

# Akṣaya + Sañcāra — OpenRouter (gemini + fallback models)
OPENROUTER_API_KEY=sk-or-...

# Javā — Groq (llama-3.3-70b, free tier available at groq.com)
GROQ_API_KEY=gsk_...

# App URL (for OpenRouter referer header)
NEXT_PUBLIC_APP_URL=https://medha.ai

# ─── Daily Token Budgets ──────────────────────────────────────────────────────
# When a faculty hits its limit it auto-kills and cascades to the next.
# Set to 0 for unlimited. Defaults shown below.

MEDHA_LIMIT_PRAJNA=50000
MEDHA_LIMIT_DHYANA=80000
MEDHA_LIMIT_AKSAYA=100000
MEDHA_LIMIT_JAVA=200000
MEDHA_LIMIT_SANCARA=150000

# ─── Manual Kill Switches ─────────────────────────────────────────────────────
# Emergency override. Set to "true" to instantly disable.
# Change in Vercel dashboard → no rebuild needed.

MEDHA_KILL_ALL=false
MEDHA_KILL_PRAJNA=false
MEDHA_KILL_DHYANA=false
MEDHA_KILL_AKSAYA=false
MEDHA_KILL_JAVA=false
MEDHA_KILL_SANCARA=false
